# ============================================
# Agile IA Assistant — Variables d'environnement
# ============================================
# Copier ce fichier en .env et remplir les valeurs
# Ne JAMAIS commiter le fichier .env

# ---- Database ----
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agile_ia

# ---- JWT ----
JWT_SECRET=change-me-in-prod
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- API ----
PORT=3000
CORS_ORIGIN=http://localhost:5173

# ---- IA (Sprint 7 — pas utilisé en Phase A) ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AGENT_PRIORITY_LLM_TIMEOUT=2000
AGENT_CHAT_LLM_TIMEOUT=5000
AI_BENCH_DATASET_PATH=./tests/fixtures/ai